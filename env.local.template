# =========================================================================
# FILE TEMPLATE HƯỚNG DẪN CẤU HÌNH MÔI TRƯỜNG (.env.local) CHO DỰ ÁN
# Hướng dẫn: Tạo file đặt tên là `.env.local` ở cùng thư mục này và sao chép
# toàn bộ nội dung bên dưới, thay thế các giá trị mẫu bằng key thực tế của bạn.
# =========================================================================

# 1. CẤU HÌNH TRÍ TUỆ NHÂN TẠO (GEMINI AI CHATBOT)
# Đăng ký và lấy key tại: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 2. CẤU HÌNH ĐỒNG BỘ PHÒNG THI ONLINE (FIREBASE CLIENT SDK - FRONTEND)
# Đăng ký dự án tại: https://console.firebase.google.com/
# Bật tính năng: Firestore Database và Anonymous Authentication (Đăng nhập ẩn danh)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_client_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# 3. CẤU HÌNH QUẢN TRỊ VIÊN BACKEND (FIREBASE ADMIN SDK - SERVER SIDE)
# Tạo và tải file Service Account Key (.json) tại: Cài đặt dự án -> Service accounts -> Generate new private key.
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_firebase_project_id.iam.gserviceaccount.com
# Nhập private key dạng chuỗi nháy kép. Copy chuẩn xác, không được xóa ký tự xuống dòng \n của private key.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# 4. CẤU HÌNH THỜI GIAN HẾT HẠN PHÒNG THI (MẶC ĐỊNH LÀ 1 GIỜ = 3600 GIÂY)
QUIZ_ROOM_TTL_SECONDS=3600
